Algoritmo "EstruturaDeRepeticao"
// Disciplina   : [ Lógica de Programaçăo com visual G ]
// Professor   : Jaildon costa dos santos
// Descriçăo   : Faz um laço de repeitçăo
// Autor(a)    : Davi Oliveira
// Data atual  : 08/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
    contadora:inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
   enquanto contadora <10 faça
   escreval("Davi")
   contadora <- contadora + 1
   fimenquanto

Fimalgoritmo